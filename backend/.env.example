# Copy this file to .env and add your credentials

# Server Configuration
PORT=3000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/axorasoft

# Email SMTP Configuration (Required for OTP)
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-app-specific-password
EMAIL_FROM="Axora Soft <your-gmail@gmail.com>"

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# MSG91 Configuration (Optional - for SMS OTP)
MSG91_AUTH_KEY=your_msg91_auth_key
